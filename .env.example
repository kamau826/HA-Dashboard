# CRM API Credentials
# Copy this file to .env and fill in your actual values

# Refresh token for CRM authentication
VITE_CRM_RTOKEN=your_refresh_token_here

# App ID (usually doesn't change)
VITE_CRM_APPID=220801001

# Employee number
VITE_CRM_EMPNO=15402568

# Notifications data URL (optional, defaults to production)
NOTIF_DATA_URL=https://ha-dashboard-two.vercel.app/data/notifications.json
